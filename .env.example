PORT=8787
NODE_ENV=production

# Defense-in-depth bearer gate for /mcp requests.
AUTH_BEARER_TOKEN=replace-with-long-random-token

# Enable OAuth-style challenge metadata for ChatGPT auth linking flows.
ENABLE_OAUTH_CHALLENGE=true
PUBLIC_BASE_URL=https://your-mcp.example.com
OAUTH_AUTHORIZATION_SERVERS=https://auth.your-company.com
OAUTH_SCOPES=knowledge.read

# CORS allowlist for browser-originated MCP calls.
ALLOWED_MCP_ORIGINS=https://chatgpt.com,https://chat.openai.com

# Tenant isolation controls.
TENANT_ID_HEADER=x-tenant-id
REQUIRE_TENANT_ID=true

# Origin and abuse protections.
ALLOW_REQUESTS_WITHOUT_ORIGIN=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Optional host allowlist for document source URLs returned to the widget.
# Example: ALLOWED_DOC_HOSTS=docs.your-company.com,help.your-company.com
ALLOWED_DOC_HOSTS=

# Autonomous automation runtime.
AUTOMATION_STORE_PATH=./data/automation-store.json
AUTOMATION_DEFAULT_ASSIGNEE=
AUTOMATION_DEFAULT_FOLLOW_UP_DAYS=2
AUTOMATION_FOLLOW_UP_INTERVAL_MS=0

# Optional AI provider credentials for higher-quality classification.
OPENAI_API_KEY=
OPENAI_AUTOMATION_MODEL=gpt-5.4
ANTHROPIC_API_KEY=
ANTHROPIC_AUTOMATION_MODEL=claude-sonnet-4-5
ANTHROPIC_VERSION=2023-06-01

# Optional downstream Notion sync. Local persistence remains the source of truth.
NOTION_SYNC_ENABLED=false
NOTION_SYNC_PROFILE=
NOTION_API_TOKEN=
NOTION_VERSION=2026-03-11
NOTION_API_BASE_URL=https://api.notion.com/v1
NOTION_SYNC_APPEND_CONTENT=true
NOTION_SYNC_TIMEOUT_MS=15000
NOTION_DEFAULT_ASSIGNEE_USER_ID=
NOTION_DEFAULT_SCOPE=Knowledge Base Global
NOTION_DEFAULT_KNOWLEDGE_DOMAIN=Operations

# Example preset for the Personal KB v2 workspace created on 2026-03-30.
# NOTION_SYNC_PROFILE=personal-kb-v2
# NOTION_DEFAULT_ASSIGNEE_USER_ID=<NOTION_ASSIGNEE_USER_ID_REDACTED>
# NOTION_DEFAULT_KNOWLEDGE_DOMAIN=work

# Set either *_DATA_SOURCE_ID or *_DATABASE_ID for each route you want to sync.
NOTION_TASK_DATA_SOURCE_ID=
NOTION_TODO_DATA_SOURCE_ID=
NOTION_RESEARCH_DATA_SOURCE_ID=
NOTION_KNOWLEDGE_DATA_SOURCE_ID=
NOTION_INCIDENT_DATA_SOURCE_ID=
NOTION_INBOX_DATA_SOURCE_ID=

# Optional database IDs if you prefer resolving data sources automatically.
NOTION_TASK_DATABASE_ID=
NOTION_TODO_DATABASE_ID=
NOTION_RESEARCH_DATABASE_ID=
NOTION_KNOWLEDGE_DATABASE_ID=
NOTION_INCIDENT_DATABASE_ID=
NOTION_INBOX_DATABASE_ID=

# Optional explicit property overrides per route when schema names differ from common defaults.
# Supported suffixes for each route prefix:
# _TITLE_PROPERTY, _STATUS_PROPERTY, _PRIORITY_PROPERTY, _DUE_DATE_PROPERTY,
# _REVIEW_DATE_PROPERTY, _SUMMARY_PROPERTY, _SOURCE_EXCERPT_PROPERTY,
# _SOURCE_CONVERSATION_ID_PROPERTY, _SOURCE_MESSAGE_ID_PROPERTY,
# _SOURCE_URL_PROPERTY, _CONFIDENCE_PROPERTY, _POLICY_MODE_PROPERTY,
# _SOURCE_CHANNEL_PROPERTY,
# _ASSIGNEE_PROPERTY, _TAGS_PROPERTY, _ACTIVITY_TYPE_PROPERTY,
# _ACTIVITY_TYPE_VALUE, _WORKFLOW_PROPERTY, _WORKFLOW_VALUE,
# _SCOPE_PROPERTY, _SCOPE_VALUE, _RECORD_TYPE_PROPERTY,
# _RECORD_TYPE_VALUE, _KNOWLEDGE_DOMAIN_PROPERTY, _KNOWLEDGE_DOMAIN_VALUE
# Example:
# NOTION_SYNC_PROFILE=knowledge-base-v1
# NOTION_TASK_TITLE_PROPERTY=Task Name
# NOTION_TASK_STATUS_PROPERTY=Status
